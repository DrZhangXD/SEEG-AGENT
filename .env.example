# ── SEEG-AGENT 环境变量模板 ──
# 复制为 .env 后填入真实 key。所有 key 都可选，留空即在前端下拉中隐藏该 provider。

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI GPT
OPENAI_API_KEY=

# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 阿里通义千问 DashScope（OpenAI 兼容模式）
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Moonshot Kimi
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 本地 Ollama（无需 key）
OLLAMA_BASE_URL=http://localhost:11434/v1

# 数据目录（缓存 Raw 对象、MNI 模板等）；默认 ~/.seeg-agent
# DATA_DIR=
